# Environment variables for multi-agent-planner
# Copy this file to .env and fill in values before running.

# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Auth ──────────────────────────────────────────────────────────────────────
# Static API key clients must send via: Authorization: Bearer <API_KEY>
# Leave blank to disable auth enforcement (development only).
API_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.  Use "*" to allow all (dev only).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Request limits ────────────────────────────────────────────────────────────
MAX_BODY_KB=10

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=20          # max requests per window per client
RATE_LIMIT_WINDOW_S=60     # sliding window in seconds

# ── LLM resilience ────────────────────────────────────────────────────────────
LLM_TIMEOUT_MS=45000       # per-call timeout in milliseconds
LLM_MAX_RETRIES=3          # max retry attempts on failure

# ── Orchestration ─────────────────────────────────────────────────────────────
MAX_ITERATIONS=7           # max planner loop iterations per run
QUEUE_CONCURRENCY=3        # max parallel runs in-process
QUEUE_MAX_SIZE=50          # max queued (not-yet-started) runs
RUN_TTL_MS=7200000         # run record lifetime in ms (default: 2h)

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
