{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["goal", "duration_days", "daily_hours", "tasks"],
  "additionalProperties": false,
  "properties": {
    "goal": { "type": "string", "minLength": 1 },
    "duration_days": { "type": "number", "minimum": 1, "maximum": 365 },
    "daily_hours":   { "type": "number", "minimum": 0.5, "maximum": 24 },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "description", "priority", "estimated_hours", "dependencies"],
        "additionalProperties": false,
        "properties": {
          "id":              { "type": "string", "pattern": "^task_\\d+$" },
          "title":           { "type": "string", "minLength": 1 },
          "description":     { "type": "string", "minLength": 1 },
          "priority":        { "type": "string", "enum": ["high", "medium", "low"] },
          "estimated_hours": { "type": "number", "minimum": 0.5 },
          "dependencies": {
            "type": "array",
            "items": { "type": "string", "pattern": "^task_\\d+$" }
          }
        }
      }
    }
  }
}
