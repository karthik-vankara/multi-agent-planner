{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["goal"],
  "additionalProperties": false,
  "properties": {
    "goal": {
      "type": "string",
      "minLength": 5,
      "maxLength": 500
    },
    "days": {
      "type": "number",
      "minimum": 1,
      "maximum": 365
    },
    "hours": {
      "type": "number",
      "minimum": 0.5,
      "maximum": 24
    }
  }
}
