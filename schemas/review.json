{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["issues", "suggestions", "score"],
  "additionalProperties": false,
  "properties": {
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "message"],
        "additionalProperties": false,
        "properties": {
          "type":    { "type": "string" },
          "message": { "type": "string" }
        }
      }
    },
    "suggestions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "score": { "type": "number", "minimum": 1, "maximum": 10 }
  }
}
